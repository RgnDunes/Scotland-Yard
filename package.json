{
  "name": "scotland-yard",
  "version": "1.0.0",
  "description": "Scotland Yard digital board game — asymmetric multiplayer detective game set in London",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src",
    "server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RgnDunes/Scotland-Yard.git"
  },
  "keywords": [
    "scotland-yard",
    "board-game",
    "multiplayer",
    "detective"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/RgnDunes/Scotland-Yard/issues"
  },
  "homepage": "https://github.com/RgnDunes/Scotland-Yard#readme",
  "dependencies": {
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "framer-motion": "^12.36.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
